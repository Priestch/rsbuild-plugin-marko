{
  "name": "playground",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npx rsbuild dev",
    "build": "node scripts/compile-templates.mjs && npx rsbuild build",
    "build:templates": "node scripts/compile-templates.mjs",
    "serve:node": "node ./server/server.mjs",
    "dev:inspect": "node --inspect --enable-source-maps ./server/server.mjs",
    "start": "node --enable-source-maps ./server/server.mjs"
  },
  "dependencies": {
    "@babel/plugin-transform-runtime": "^7.25.7",
    "@babel/preset-env": "^7.25.8",
    "@marko/express": "^2.1.0",
    "@marko/runtime-tags": "^6.0.145",
    "@rsbuild/core": "^2.0.0-beta.4",
    "@rspack/core": "^2.0.0-beta.2",
    "express": "^4.21.1",
    "rsbuild-plugin-marko": "workspace:*"
  },
  "devDependencies": {
    "postcss-load-config": "^6.0.1"
  }
}
